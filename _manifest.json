{
  "manifest_version": 2,
  "id": "maimai-drawpic-plugin",
  "version": "1.10.3",
  "name": "麦麦绘图",
  "description": "让麦麦拥有图片创建与图片编辑的能力，支持多平台图片模型",
  "author": {
    "name": "清蒸云鸭",
    "url": "https://github.com/WhiteCloudOL"
  },
  "license": "AGPL-3.0",
  "urls": {
    "repository": "https://github.com/WhiteCloudOL/maimai-drawpic-plugin",
    "homepage": "https://github.com/WhiteCloudOL/maimai-drawpic-plugin",
    "documentation": "https://github.com/WhiteCloudOL/maimai-drawpic-plugin/README.md",
    "issues": "https://github.com/WhiteCloudOL/maimai-drawpic-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
	{"type": "python_package", "name": "aiohttp", "version_spec": ">=3.0.0"},
	{"type": "python_package", "name": "google-genai", "version_spec": ">=1.58.0"},
	{"type": "python_package", "name": "pillow", "version_spec": ">=9.0.0"}
  ],
  "capabilities": [
    "send.text",
    "send.image",
    "llm.generate",
    "chat.get_all_streams",
    "chat.get_group_streams",
    "chat.get_private_streams",
    "chat.open_session",
    "chat.get_stream_by_group_id",
    "chat.get_stream_by_user_id",
    "message.get_recent",
    "message.get_by_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "i18n",
    "supported_locales": ["zh-CN"]
  },
  "display": {
    "icon": {
      "type": "local",
      "value": "assets/icon.png",
      "fallback": "database",
      "background": "#eff6fe"
    }
  }
}
